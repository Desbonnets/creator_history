# Copier ce fichier en .env et renseigner les valeurs avant le déploiement en production.

# Clé secrète JWT — générer avec : openssl rand -hex 32
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32

# URL du frontend exposée (utilisée pour le CORS)
FRONTEND_URL=https://votre-domaine.com

# Credentials de l'admin initial (utilisés uniquement au premier démarrage)
# Une fois l'admin créé dans data/admin.json, ces variables n'ont plus d'effet.
ADMIN_IDENTIFIER=admin
ADMIN_INITIAL_PASSWORD=changeme-strong-password
